# URL base da API (backend). Em produção: a URL do Render.
VITE_API_URL="http://localhost:3000"

# Links entre os apps (usados na landing/rodapé). Em produção, as URLs da Vercel.
VITE_CLIENT_URL="http://localhost:5173"
VITE_PROVIDER_URL="http://localhost:5174"
VITE_ADMIN_URL="http://localhost:5175"

# Marca (sobrescreve os defaults de @orcalink/design-tokens)
# VITE_BRAND_NAME="OrcaLink"
# VITE_BRAND_DOMAIN="orcalink.com.br"

# ─────────────────────────────────────────────────────────────
# Push Notifications (Firebase Cloud Messaging) — OPCIONAL.
# Config PÚBLICA do app web (Firebase Console → Configurações do projeto →
# Seus apps → App Web → "Configuração do SDK"). NÃO é secreto.
# Deixe em branco para desativar o Push (Toast/WebSocket seguem funcionando).
# ─────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=          # opcional (derivado de <projectId>.firebaseapp.com)
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Cloud Messaging → Web configuration → "Certificados push da Web" (chave pública/VAPID)
VITE_FIREBASE_VAPID_KEY=
